# ──────────────────────────────────────────────────────────────
# Elixir Insight — environment variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# Supabase project URL (from Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase anon/public key (safe to expose in browser; RLS is the security boundary)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...YOUR_ANON_KEY

# Supabase project ref (used by Supabase CLI)
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# ──────────────────────────────────────────────────────────────
# The following are only needed for Supabase Edge Functions
# (set these in the Supabase dashboard under Project → Edge Functions → Secrets)
# Do NOT put them in this file for production — only for local dev.
# ──────────────────────────────────────────────────────────────

# AI gateway API key (Lovable gateway or direct Google AI / Anthropic key)
# LOVABLE_API_KEY=your_key_here
